{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user registered."
        }
      }
    },
    "HubSpotConnection": {
      "title": "HubSpot Connection",
      "description": "Stores the OAuth connection details for HubSpot.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this connection."
        },
        "hubDomain": {
          "type": "string",
          "description": "The connected HubSpot domain."
        },
        "access_token": {
          "type": "string"
        },
        "refresh_token": {
          "type": "string"
        },
        "expires_in": {
          "type": "number"
        },
        "hub_id": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId"]
    },
    "WixConnection": {
      "title": "Wix Connection",
      "description": "Stores the OAuth connection details for Wix.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "access_token": {
          "type": "string"
        },
        "refresh_token": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId"]
    },
    "ContactMapping": {
      "title": "Contact Mapping",
      "description": "Loop prevention mapping for contacts.",
      "type": "object",
      "properties": {
        "wixContactId": {
          "type": "string"
        },
        "hubspotContactId": {
          "type": "string"
        },
        "lastSyncedAt": {
          "type": "number"
        },
        "source": {
          "type": "string"
        },
        "syncId": {
          "type": "string"
        }
      },
      "required": ["wixContactId", "hubspotContactId", "lastSyncedAt", "source", "syncId"]
    },
    "SyncLog": {
      "title": "Sync Log",
      "description": "Audit log for sync operations.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "operationType": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "wixContactId": {
          "type": "string"
        },
        "hubspotContactId": {
          "type": "string"
        }
      },
      "required": ["userId", "timestamp", "operationType", "source", "status", "message"]
    },
    "FieldMapping": {
      "title": "Field Mapping",
      "description": "Configuration for syncing fields between Wix and HubSpot.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the mapping."
        },
        "wixField": {
          "type": "string",
          "description": "The field name in Wix."
        },
        "hubspotProperty": {
          "type": "string",
          "description": "The property name in HubSpot."
        },
        "direction": {
          "type": "string",
          "enum": ["wix-to-hubspot", "hubspot-to-wix", "bi-directional"],
          "description": "The direction of synchronization."
        }
      },
      "required": ["wixField", "hubspotProperty", "direction"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profiles."
    },
    "/hubspot_connections/{userId}": {
      "schema": {
        "$ref": "#/entities/HubSpotConnection"
      },
      "description": "Stores HubSpot OAuth connection details per user."
    },
    "/wix_connections/{userId}": {
      "schema": {
        "$ref": "#/entities/WixConnection"
      },
      "description": "Stores Wix OAuth connection details per user."
    },
    "/contact_mappings/{syncId}": {
      "schema": {
        "$ref": "#/entities/ContactMapping"
      },
      "description": "Stores contact mappings to prevent sync loops."
    },
    "/sync_logs/{logId}": {
      "schema": {
        "$ref": "#/entities/SyncLog"
      },
      "description": "Stores sync audit logs."
    },
    "/users/{userId}/mappings/{mappingId}": {
      "schema": {
        "$ref": "#/entities/FieldMapping"
      },
      "description": "Stores field mappings for a specific user."
    }
  }
}
